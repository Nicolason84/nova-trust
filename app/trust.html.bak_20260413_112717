<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>NOVA TRUST V9.6 · FUSION</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    html,body{margin:0;padding:0;background:#04070d;color:#edf2fb;font-family:Arial,sans-serif}
    .page{min-height:100vh;padding:28px}
    .top{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:18px}
    .badge{font-size:13px;letter-spacing:.14em;opacity:.72}
    .btn{padding:10px 14px;border-radius:12px;border:1px solid rgba(255,255,255,.16);background:#101826;color:#edf2fb;text-decoration:none}
    h1{margin:0 0 8px 0;font-size:36px}
    p.sub{margin:0 0 20px 0;opacity:.78}
    .grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}
    .card{border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:18px;background:rgba(255,255,255,.03)}
    .k{font-size:12px;opacity:.66;text-transform:uppercase;letter-spacing:.08em}
    .v{font-size:28px;margin-top:8px;font-weight:700}
    .wide{grid-column:span 2}
    .full{grid-column:1 / -1}
    pre{white-space:pre-wrap;word-break:break-word;background:#0a1018;padding:16px;border-radius:14px;border:1px solid rgba(255,255,255,.08);margin:0}
    .actions{display:flex;gap:12px;margin:18px 0}
    button{padding:12px 16px;border-radius:12px;border:1px solid rgba(255,255,255,.16);background:#101826;color:#edf2fb;cursor:pointer}
    input{width:100%;box-sizing:border-box;padding:14px 16px;border-radius:12px;border:1px solid rgba(255,255,255,.15);background:#0a1018;color:#edf2fb;font-size:16px}
    @media (max-width: 980px){.grid{grid-template-columns:repeat(2,minmax(0,1fr))}.wide{grid-column:span 2}}
    @media (max-width: 640px){.grid{grid-template-columns:1fr}.wide,.full{grid-column:auto}.top{flex-direction:column;align-items:flex-start}}
  </style>
</head>
<body>
  <div class="page">
    <div class="top">
      <div>
        <div class="badge">NOVA TRUST · V9.6 · MATCH2 FUSION</div>
        <h1>Analyse de confiance</h1>
        <p class="sub">Fusion analyse opérateur + score business live</p>
      </div>
      <a class="btn" href="/">Retour VX</a>
    </div>

    <div class="actions">
      <button id="refresh">Refresh live</button>
      <button id="analyze">Fusion trust</button>
    </div>

    <div class="card full" style="margin-bottom:14px">
      <div class="k">Entrée opérateur</div>
      <div style="margin-top:10px">
        <input id="target" placeholder="Colle ici un lien, un message ou un texte à analyser">
      </div>
    </div>

    <div class="grid">
      <div class="card"><div class="k">Status</div><div class="v" id="status">—</div></div>
      <div class="card"><div class="k">App</div><div class="v" id="app">—</div></div>
      <div class="card"><div class="k">Cash</div><div class="v" id="cash">—</div></div>
      <div class="card"><div class="k">Payments</div><div class="v" id="payments">—</div></div>

      <div class="card"><div class="k">Offer</div><div class="v" id="offer">—</div></div>
      <div class="card wide"><div class="k">CTA</div><div class="v" id="cta" style="font-size:20px">—</div></div>
      <div class="card"><div class="k">Business Score</div><div class="v" id="business_score">—</div></div>

      <div class="card"><div class="k">Lead</div><div class="v" id="lead">—</div></div>
      <div class="card"><div class="k">Lead Status</div><div class="v" id="lead_status">—</div></div>
      <div class="card"><div class="k">Lead Action</div><div class="v" id="lead_action">—</div></div>
      <div class="card"><div class="k">Engine</div><div class="v" id="engine" style="font-size:18px">—</div></div>

      <div class="card"><div class="k">Analysis Score</div><div class="v" id="analysis_score">—</div></div>
      <div class="card"><div class="k">Fusion Score</div><div class="v" id="fusion_score">—</div></div>
      <div class="card wide"><div class="k">Fusion Verdict</div><div class="v" id="fusion_verdict" style="font-size:22px">—</div></div>

      <div class="card full">
        <div class="k">Decision Rationale</div>
        <pre id="rationale">En attente.</pre>
      </div>

      <div class="card full">
        <div class="k">Fusion JSON</div>
        <pre id="analysis">En attente.</pre>
      </div>

      <div class="card full">
        <div class="k">Raw JSON live</div>
        <pre id="raw">Chargement…</pre>
      </div>
    </div>
  </div>

  <script>
    const ids = {
      status: document.getElementById("status"),
      app: document.getElementById("app"),
      cash: document.getElementById("cash"),
      payments: document.getElementById("payments"),
      offer: document.getElementById("offer"),
      cta: document.getElementById("cta"),
      business_score: document.getElementById("business_score"),
      lead: document.getElementById("lead"),
      lead_status: document.getElementById("lead_status"),
      lead_action: document.getElementById("lead_action"),
      engine: document.getElementById("engine"),
      analysis_score: document.getElementById("analysis_score"),
      fusion_score: document.getElementById("fusion_score"),
      fusion_verdict: document.getElementById("fusion_verdict"),
      rationale: document.getElementById("rationale"),
      analysis: document.getElementById("analysis"),
      raw: document.getElementById("raw"),
      target: document.getElementById("target")
    };

    function val(x, fb="—") {
      return (x === undefined || x === null || x === "") ? fb : String(x);
    }

    function renderLive(j) {
      ids.status.textContent = val(j.status || (j.ok ? "LIVE" : "DOWN"));
      ids.app.textContent = val(j.app || j.key);
      ids.cash.textContent = val(j.cash);
      ids.payments.textContent = val(j.payments);
      ids.offer.textContent = val(j.recommended_offer);
      ids.cta.textContent = val(j.cta);
      ids.business_score.textContent = val(j.score);
      ids.lead.textContent = val(j.best_lead_id);
      ids.lead_status.textContent = val(j.best_lead_status);
      ids.lead_action.textContent = val(j.best_lead_action);
      ids.engine.textContent = val(j.engine);
      ids.raw.textContent = JSON.stringify(j, null, 2);
    }

    async function loadLive() {
      try {
        const r = await fetch("/api/trust/live?ts=" + Date.now(), {cache: "no-store"});
        const j = await r.json();
        renderLive(j);
      } catch (e) {
        ids.raw.textContent = JSON.stringify({ok:false,error:String(e)}, null, 2);
      }
    }

    async function runFusion() {
      try {
        const v = ids.target.value.trim();
        const r = await fetch("/api/trust/fuse?q=" + encodeURIComponent(v), {cache: "no-store"});
        const j = await r.json();
        ids.analysis_score.textContent = val(j.analysis_score);
        ids.fusion_score.textContent = val(j.fusion_score);
        ids.fusion_verdict.textContent = val(j.fusion_verdict);
        ids.rationale.textContent = JSON.stringify(j.rationale || [], null, 2);
        ids.analysis.textContent = JSON.stringify(j, null, 2);
      } catch (e) {
        ids.analysis.textContent = JSON.stringify({ok:false,error:String(e)}, null, 2);
      }
    }

    document.getElementById("refresh").addEventListener("click", loadLive);
    document.getElementById("analyze").addEventListener("click", runFusion);
    loadLive();
    setInterval(loadLive, 10000);
  </script>
</body>
</html>
